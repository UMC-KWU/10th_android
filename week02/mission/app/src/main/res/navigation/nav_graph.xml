<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.neouul.umc10android.week02.presentation.fragment.HomeFragment"
        android:label="홈"
        tools:layout="@layout/fragment_home">
        <argument
            android:name="title"
            app:argType="string"
            android:defaultValue="default" />
    </fragment>

    <fragment
        android:id="@+id/shopFragment"
        android:name="com.neouul.umc10android.week02.presentation.fragment.ShopFragment"
        android:label="구매하기"
        tools:layout="@layout/fragment_shop" />

    <fragment
        android:id="@+id/wishFragment"
        android:name="com.neouul.umc10android.week02.presentation.fragment.WishFragment"
        android:label="위시리스트"
        tools:layout="@layout/fragment_wish" />

    <fragment
        android:id="@+id/cartFragment"
        android:name="com.neouul.umc10android.week02.presentation.fragment.CartFragment"
        android:label="장바구니"
        tools:layout="@layout/fragment_cart">

        <!-- Cart -> Shop 로 이동하는 action 추가 -->
        <action
            android:id="@+id/action_homeFragment_to_shopFragment"
            app:destination="@id/shopFragment"
            app:popUpTo="@id/cartFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.neouul.umc10android.week02.presentation.fragment.ProfileFragment"
        android:label="프로필"
        tools:layout="@layout/fragment_profile" />
</navigation>
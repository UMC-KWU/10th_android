<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/iv_bag"
        app:layout_constraintVertical_chainStyle="packed"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/ic_bag_circle"
        app:layout_constraintBottom_toTopOf="@id/tv_empty_cart"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_empty_cart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="40dp"
        android:layout_marginTop="27dp"
        android:maxLines="2"
        android:text="장바구니가 비어 있습니다.\n제품을 추가하면 여기에 표시됩니다."
        android:textAlignment="center"
        app:layout_constraintBottom_toTopOf="@id/btn_order"
        app:layout_constraintTop_toBottomOf="@id/iv_bag" />


    <Button
        android:id="@+id/btn_order"
        android:layout_width="match_parent"
        android:layout_height="51dp"
        android:layout_marginHorizontal="40dp"
        android:fontFamily="@font/noto_sans_medium"
        android:includeFontPadding="false"
        android:text="주문하기"
        android:textSize="16sp"
        android:textColor="@color/white"
        android:backgroundTint="@color/black"
        app:layout_constraintBottom_toBottomOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    >
    <TextView
        android:id="@+id/discover"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Discover"
        android:textStyle="bold"
        android:textSize="28sp"
        android:layout_marginTop="50dp"
        android:layout_marginStart="41dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        />
    <TextView
        android:id="@+id/date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="9월 4일 목요일"
        android:textSize="16sp"
        android:layout_marginTop="44dp"
        android:layout_marginStart="41dp"
        app:layout_constraintTop_toTopOf="@+id/discover"
        app:layout_constraintStart_toStartOf="parent"
        />
    <ImageView
        android:id="@+id/nikehome"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:src="@mipmap/ic_nikehome"
        android:layout_marginTop="68dp"
        app:layout_constraintTop_toTopOf="@+id/discover"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />
    
    <TextView
        android:id = "@+id/what"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="What's new?"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="0dp"
        android:layout_marginStart="42dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/nikehome"
        />

    <TextView
        android:id = "@+id/nike_product"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="나이키 최신 상품"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#767676"
        android:layout_marginTop="12dp"
        android:layout_marginStart="42dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/what"
        />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/Home_recyclerview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:scrollbars="horizontal"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/nike_product"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
    
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="16dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <ImageView
        android:id="@+id/img_product"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        android:scaleType="centerCrop"
        android:src="@drawable/img_detail"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/ic_heart"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:padding="7dp"
        android:layout_margin="8dp"
        android:src="@drawable/ic_heart_empty"
        app:layout_constraintTop_toTopOf="@+id/img_product"
        app:layout_constraintEnd_toEndOf="@+id/img_product"
        android:background="@drawable/bg_circle"
        android:backgroundTint="@color/white" />

    <TextView
        android:id="@+id/tv_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:maxLines="2"
        android:ellipsize="end"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@+id/img_product"
        app:layout_constraintStart_toStartOf="@+id/img_product"
        app:layout_constraintEnd_toEndOf="@+id/img_product"
        android:text="Nike Everyday Plus Cushioned"/>

    <TextView
        android:id="@+id/tv_des"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:maxLines="2"
        android:ellipsize="end"
        android:textSize="14sp"
        android:textColor="@color/gray1"
        app:layout_constraintTop_toBottomOf="@+id/tv_name"
        app:layout_constraintStart_toStartOf="@+id/img_product"
        app:layout_constraintEnd_toEndOf="@+id/img_product"
        android:text="Training Ankle Socks (6 Pairs)"/>

    <TextView
        android:id="@+id/tv_color_number"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textSize="14sp"
        android:textColor="@color/gray1"
        app:layout_constraintTop_toBottomOf="@+id/tv_des"
        app:layout_constraintStart_toStartOf="@+id/img_product"
        app:layout_constraintEnd_toEndOf="@+id/img_product"
        android:text="5 Colours"/>

    <TextView
        android:id="@+id/tv_price"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@+id/tv_color_number"
        app:layout_constraintStart_toStartOf="@+id/img_product"
        app:layout_constraintEnd_toEndOf="@+id/img_product"
        android:text="US$10"/>

</androidx.constraintlayout.widget.ConstraintLayout>
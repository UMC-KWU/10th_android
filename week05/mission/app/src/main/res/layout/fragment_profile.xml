<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/iv_profile"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:layout_marginTop="21dp"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/gray3"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_nickname"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:fontFamily="@font/noto_sans_medium"
            android:includeFontPadding="false"
            android:text="프로필"
            android:textSize="20sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/iv_profile" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_modify_profile"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="180dp"
            android:layout_height="51dp"
            android:layout_marginTop="30dp"
            android:backgroundTint="@color/white"
            android:fontFamily="@font/noto_sans_medium"
            android:includeFontPadding="false"
            android:text="프로필 수정"
            android:textColor="@color/black"
            android:textSize="16sp"
            app:cornerRadius="100dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_nickname"
            app:strokeColor="@color/gray2"
            app:strokeWidth="1dp" />

        <LinearLayout
            android:id="@+id/tap_profile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="43dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/btn_modify_profile"
            android:orientation="horizontal">

            <!--    주문    -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_archive" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textSize="12sp"
                    android:text="주문" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="31dp"
                android:background="@color/gray5" />

            <!--    패스    -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_identificationic_card" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textSize="12sp"
                    android:text="패스" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="31dp"
                android:background="@color/gray5" />

            <!--    이벤트    -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_calendar_blank" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textSize="12sp"
                    android:text="이벤트" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="31dp"
                android:background="@color/gray5" />

            <!--    설정    -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_gear" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textSize="12sp"
                    android:text="설정" />
            </LinearLayout>

        </LinearLayout>

        <View
            android:id="@+id/divider1"
            android:layout_width="match_parent"
            android:layout_height="7.55dp"
            android:layout_marginTop="25dp"
            android:background="@color/gray4"
            app:layout_constraintTop_toBottomOf="@id/tap_profile" />


        <LinearLayout
            android:id="@+id/member"
            android:layout_width="match_parent"
            android:layout_height="101dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="24dp"
            app:layout_constraintTop_toBottomOf="@+id/divider1">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="나이키 멤버 혜택"
                    android:textSize="16dp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0개 사용 가능"
                    android:textColor="@color/gray1"
                    android:textSize="12dp" />

            </LinearLayout>

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:rotation="180"
                android:src="@drawable/ic_back" />

        </LinearLayout>

        <View
            android:id="@+id/divider2"
            android:layout_width="match_parent"
            android:layout_height="7.55dp"
            android:background="@color/gray4"
            app:layout_constraintTop_toBottomOf="@id/member" />


        <!--    팔로잉    -->
        <RelativeLayout
            android:id="@+id/following"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="28dp"
            app:layout_constraintTop_toBottomOf="@id/divider2">

            <TextView
                android:id="@+id/tv_following"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="팔로잉 (n)"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/btn_edit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="편집"
                android:textColor="@color/gray1"
                android:textSize="12sp" />

        </RelativeLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/following_recyclerview"
            android:layout_width="match_parent"
            android:layout_height="108dp"
            android:layout_marginTop="16dp"
            android:clipToPadding="false"
            android:paddingHorizontal="24dp"
            android:scrollbars="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintTop_toBottomOf="@id/following" />

        <!--    회원 가입일    -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="24dp"
            android:background="@color/gray4"
            android:gravity="center"
            android:text="회원 가입일: 2025년 9월"
            android:textColor="@color/gray1"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/following_recyclerview"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
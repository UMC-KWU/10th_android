<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="70dp"
        android:paddingBottom="24dp">

        <!-- 프로필 이미지 -->
        <ImageView
            android:id="@+id/iv_profile_avatar"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_circle_gray"
            android:clipToOutline="true"
            android:contentDescription="profile image"
            android:scaleType="centerCrop" />

        <!-- 닉네임 -->
        <TextView
            android:id="@+id/tv_profile_nickname"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:text="닉네임"
            android:textColor="@android:color/black"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- 프로필 수정 버튼 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_profile_edit"
            android:layout_width="180dp"
            android:layout_height="52dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:backgroundTint="@android:color/white"
            android:text="프로필 수정"
            android:textColor="@android:color/black"
            android:textSize="14sp"
            app:cornerRadius="26dp"
            app:strokeColor="#E2E2E2"
            app:strokeWidth="1dp" />

        <!-- 주문 / 패스 / 이벤트 / 설정 메뉴 영역 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="78dp"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <!-- 주문 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/iv_profile_order"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="주문"
                    android:src="@drawable/ic_profile_order"
                    android:tint="#B8B8B8" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="주문"
                    android:textColor="@android:color/black"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="38dp"
                android:background="#E1E1E1" />

            <!-- 패스 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/iv_profile_pass"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="패스"
                    android:src="@drawable/ic_profile_pass"
                    android:tint="#B8B8B8" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="패스"
                    android:textColor="@android:color/black"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="38dp"
                android:background="#E1E1E1" />

            <!-- 이벤트 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/iv_profile_event"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="이벤트"
                    android:src="@drawable/ic_profile_event"
                    android:tint="#B8B8B8" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="이벤트"
                    android:textColor="@android:color/black"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="38dp"
                android:background="#E1E1E1" />

            <!-- 설정 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/iv_profile_setting"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="설정"
                    android:src="@drawable/ic_profile_setting"
                    android:tint="#B8B8B8" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="설정"
                    android:textColor="@android:color/black"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <!-- 회색 구분선 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_marginTop="8dp"
            android:background="#F4F4F4" />

        <!-- 나이키 멤버 혜택 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="나이키 멤버 혜택"
                    android:textColor="@android:color/black"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="0개 사용 가능"
                    android:textColor="#8A8A8A"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="›"
                android:textColor="@android:color/black"
                android:textSize="34sp" />
        </LinearLayout>

        <!-- 회색 구분선 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:background="#F4F4F4" />

        <!-- 팔로잉 제목 영역 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <TextView
                android:id="@+id/tv_following_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="팔로잉 (0)"
                android:textColor="@android:color/black"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="편집"
                android:textColor="#8A8A8A"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- 팔로잉 RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_following"
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:layout_marginTop="16dp"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingStart="24dp"
            android:paddingEnd="16dp"
            android:scrollbars="none" />

        <!-- 아래 여백 -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="100dp" />

        <!-- 회원 가입일 -->
        <TextView
            android:id="@+id/tv_join_date"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"
            android:background="#F6F6F6"
            android:gravity="center"
            android:text="회원 가입일: 2025년 9월"
            android:textColor="#8A8A8A"
            android:textSize="12sp" />

    </LinearLayout>
</ScrollView>